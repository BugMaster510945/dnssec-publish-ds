#!/usr/bin/make -f

# Version ldflags injected by CI (debian/version.ldflags generated by "Debian Prepare Source" job)
INJECTED_LDFLAGS := $(shell test -f debian/version.ldflags && cat debian/version.ldflags || true)
export DH_GOPKG := gitlab.syshawk.com/planchon/dnssec-publish-ds

# Enforce Debian-packaged dependencies only: no module proxy/network downloads.
export GOPROXY := off
export GOSUMDB := off

# Keep debhelper's build directory explicit.
# Rationale:
# - isolates dh_golang/dh_auto_* work files from the source tree;
# - matches common Debian Go packaging patterns;
# - avoids mixing debhelper temporary GOPATH/workspace artifacts with project files.
%:
	dh $@ --with=golang --buildsystem=golang --builddirectory=_build

override_dh_auto_configure:
	dh_auto_configure --buildsystem=golang --builddirectory=_build


BIN_PATH := _build/bin/dnssec-publish-ds
override_dh_auto_build-arch:
	# Compile binary and generate completions during arch-specific builds
	dh_auto_build --buildsystem=golang --builddirectory=_build -- -ldflags "$(INJECTED_LDFLAGS)"
	mkdir -p completions
	$(BIN_PATH) completion bash > completions/dnssec-publish-ds.bash
	$(BIN_PATH) completion zsh > completions/_dnssec-publish-ds
	$(BIN_PATH) completion fish > completions/dnssec-publish-ds.fish
	mmark -man man/dnssec-publish-ds.8.md > man/dnssec-publish-ds.8

override_dh_auto_install-indep override_dh_auto_install-arch:
	# On install sans go qui est buggue
	:

override_dh_auto_build-indep:
	mmark -man man/xymon-ext-dnssec.1.md > man/xymon-ext-dnssec.1

override_dh_auto_clean:
	# Remove built artefacts so next build starts fresh
	rm -rf completions
	dh_auto_clean --buildsystem=golang --builddirectory=_build

override_dh_auto_test:
	# Tests require network access; skip in package build

override_dh_dwz:
	# Go binaries may contain compressed DWARF sections that older dwz
	# versions cannot process reliably.
	:
